{
  "name": "Admin — Model & Prompt Versioning",
  "item": [
    {
      "name": "Get Active Model (OpenAI)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{tenantToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/admin/model-config/openai",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "admin",
            "model-config",
            "openai"
          ]
        }
      }
    },
    {
      "name": "Get Active Model (Gemini)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{tenantToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/admin/model-config/gemini",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "admin",
            "model-config",
            "gemini"
          ]
        }
      }
    },
    {
      "name": "Get Model History (OpenAI)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{tenantToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/admin/model-config/openai/history",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "admin",
            "model-config",
            "openai",
            "history"
          ]
        }
      }
    },
    {
      "name": "Set Active Model (OpenAI)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Model updated', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{tenantToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"modelName\": \"gpt-4.1\",\n  \"notes\": \"Testing GPT-4.1 for finance chat\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/model-config/openai",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "admin",
            "model-config",
            "openai"
          ]
        }
      }
    },
    {
      "name": "Rollback Model (OpenAI)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Model rolled back', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{tenantToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": ""
        },
        "url": {
          "raw": "{{baseUrl}}/admin/model-config/openai/rollback",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "admin",
            "model-config",
            "openai",
            "rollback"
          ]
        }
      }
    },
    {
      "name": "List Prompt Template Versions",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{tenantToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/admin/prompt-templates/finance_chat/versions",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "admin",
            "prompt-templates",
            "finance_chat",
            "versions"
          ]
        }
      }
    },
    {
      "name": "Publish New Prompt Version",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Version published', () => pm.response.to.have.status(201));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{tenantToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"content\": \"You are a concise financial assistant.\\n\\n=== KPI SUMMARY ===\\n{{kpiSummary}}\\n\\n=== RECENT ANOMALIES ===\\n{{anomalySummary}}\\n\\n=== RELATED ENTITIES ===\\n{{entityGraph}}\\n\\nAnswer in 2-3 sentences maximum.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/prompt-templates/finance_chat/publish",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "admin",
            "prompt-templates",
            "finance_chat",
            "publish"
          ]
        }
      }
    },
    {
      "name": "Rollback Prompt Template",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Template rolled back', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{tenantToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": ""
        },
        "url": {
          "raw": "{{baseUrl}}/admin/prompt-templates/finance_chat/rollback",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "admin",
            "prompt-templates",
            "finance_chat",
            "rollback"
          ]
        }
      }
    }
  ]
}