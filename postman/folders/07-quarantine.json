{
  "name": "Quarantine",
  "item": [
    {
      "name": "List Quarantine Records",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{tenantToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/quarantine",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "quarantine"
          ]
        }
      }
    },
    {
      "name": "Get Quarantine Status",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{tenantToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/quarantine/status",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "quarantine",
            "status"
          ]
        }
      }
    },
    {
      "name": "Retry Quarantine Record",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{tenantToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fixedData\": {\n    \"customer_name\": \"Fixed Customer Corp\",\n    \"amount\": 2000.00,\n    \"external_id\": \"INV-101\",\n    \"status\": \"paid\",\n    \"currency\": \"USD\"\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/quarantine/{{quarantineId}}/retry",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "quarantine",
            "{{quarantineId}}",
            "retry"
          ]
        }
      }
    }
  ]
}