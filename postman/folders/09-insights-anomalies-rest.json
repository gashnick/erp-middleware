{
  "name": "Insights (Anomalies) — REST",
  "item": [
    {
      "name": "1. Trigger Anomaly Scan",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Scan enqueued', () => { pm.response.to.have.status(201); pm.expect(pm.response.json().jobId).to.exist; });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{tenantToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": ""
        },
        "url": {
          "raw": "{{baseUrl}}/insights/scan",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "insights",
            "scan"
          ]
        }
      }
    },
    {
      "name": "2. List Insights",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns array', () => pm.response.to.have.status(200));",
              "const r = pm.response.json();",
              "const list = Array.isArray(r) ? r : (r.data ?? []);",
              "if (list.length) { pm.collectionVariables.set('insightId', list[0].id); console.log('insightId:', list[0].id); }"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{tenantToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/insights?types=EXPENSE_SPIKE,DUPLICATE_INVOICE&minScore=0.5",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "insights"
          ],
          "query": [
            {
              "key": "types",
              "value": "EXPENSE_SPIKE,DUPLICATE_INVOICE"
            },
            {
              "key": "minScore",
              "value": "0.5"
            }
          ]
        }
      }
    },
    {
      "name": "3. Get Insight",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{tenantToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/insights/{{insightId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "insights",
            "{{insightId}}"
          ]
        }
      }
    },
    {
      "name": "4. Submit Insight Feedback",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const id = pm.collectionVariables.get('insightId');",
              "if (!id) throw new Error('insightId not set — run List Insights first');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Feedback created', () => { pm.response.to.have.status(201); pm.expect(pm.response.json().id).to.exist; });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{tenantToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"rating\": \"helpful\",\n  \"comment\": \"This correctly flagged a seasonal spike.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/insights/{{insightId}}/feedback",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "insights",
            "{{insightId}}",
            "feedback"
          ]
        }
      }
    }
  ]
}