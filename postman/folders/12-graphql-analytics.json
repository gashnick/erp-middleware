{
  "name": "GraphQL — Analytics",
  "item": [
    {
      "name": "Revenue by Month",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{tenantToken}}"
          },
          {
            "key": "x-tenant-id",
            "value": "{{tenantId}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": \"query RevenueByMonth($year: Int!) {\\n  revenueByMonth(year: $year) {\\n    month year revenue currency\\n  }\\n}\",\n  \"variables\": { \"year\": 2026 }\n}"
        },
        "url": {
          "raw": "{{graphqlUrl}}",
          "host": [
            "{{graphqlUrl}}"
          ]
        }
      }
    },
