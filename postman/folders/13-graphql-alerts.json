{
  "name": "GraphQL — Alerts",
  "item": [
    {
      "name": "List Alert Rules",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{tenantToken}}"
          },
          {
            "key": "x-tenant-id",
            "value": "{{tenantId}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": \"query AlertRules($isActive: Boolean) {\\n  alertRules(isActive: $isActive)\\n}\",\n  \"variables\": { \"isActive\": true }\n}"
        },
        "url": {
          "raw": "{{graphqlUrl}}",
          "host": [
            "{{graphqlUrl}}"
          ]
        }
      }
    },
