{
  "name": "Subscription & Feature Flags",
  "item": [
    {
      "name": "1. Get Current Plan",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns subscription details', () => {",
              "  pm.response.to.have.status(200);",
              "  const r = pm.response.json();",
              "  pm.expect(r.planSlug).to.exist;",
              "  console.log('Current plan:', r.planSlug, '| Max seats:', r.maxSeats);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{tenantToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/subscription",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "subscription"
          ]
        }
      }
    },
    {
      "name": "2. Get Usage Summary",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns usage array', () => {",
              "  pm.response.to.have.status(200);",
              "  const r = pm.response.json();",
              "  pm.expect(r).to.be.an('array');",
              "  r.forEach(f => console.log(f.feature, ':', f.used, '/', f.limit ?? 'unlimited'));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{tenantToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/subscription/usage",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "subscription",
            "usage"
          ]
        }
      }
    },
    {
      "name": "3. Get Seats",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns seat info', () => {",
              "  pm.response.to.have.status(200);",
              "  const r = pm.response.json();",
              "  if (r.users?.length) pm.collectionVariables.set('targetUserId', r.users[0].id);",
              "  console.log('Seats:', r.used, '/', r.max);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{tenantToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/subscription/seats",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "subscription",
            "seats"
          ]
        }
      }
    },
    {
      "name": "4. Upgrade Plan",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Plan upgraded', () => { pm.response.to.have.status(200); });"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{tenantToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"planSlug\": \"enterprise\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/subscription/upgrade",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "subscription",
            "upgrade"
          ]
        }
      }
    },
    {
      "name": "5. Downgrade Plan",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Plan downgraded', () => { pm.response.to.have.status(200); });"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{tenantToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"planSlug\": \"standard\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/subscription/downgrade",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "subscription",
            "downgrade"
          ]
        }
      }
    },
    {
      "name": "6. Deactivate Seat",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const id = pm.collectionVariables.get('targetUserId');",
              "if (!id) throw new Error('targetUserId not set — run Get Seats first');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Seat deactivated', () => { pm.response.to.have.status(200); });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{tenantToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": ""
        },
        "url": {
          "raw": "{{baseUrl}}/subscription/seats/{{targetUserId}}/deactivate",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "subscription",
            "seats",
            "{{targetUserId}}",
            "deactivate"
          ]
        }
      }
    },
    {
      "name": "7. Activate Seat",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const id = pm.collectionVariables.get('targetUserId');",
              "if (!id) throw new Error('targetUserId not set — run Get Seats first');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Seat activated', () => { pm.response.to.have.status(200); });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{tenantToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": ""
        },
        "url": {
          "raw": "{{baseUrl}}/subscription/seats/{{targetUserId}}/activate",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "subscription",
            "seats",
            "{{targetUserId}}",
            "activate"
          ]
        }
      }
    },
    {
      "name": "List Subscription Plans",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/subscription-plans",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "subscription-plans"
          ]
        }
      }
    }
  ]
}