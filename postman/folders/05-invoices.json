{
  "name": "Invoices",
  "item": [
    {
      "name": "Create Invoice",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const r = pm.response.json();",
              "if (r.id) pm.collectionVariables.set('invoiceId', r.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{tenantToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customer_name\": \"Client Corp\",\n  \"amount\": 5000.00,\n  \"currency\": \"USD\",\n  \"status\": \"paid\",\n  \"invoice_date\": \"2024-03-15T00:00:00Z\",\n  \"due_date\": \"2024-04-15T00:00:00Z\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/invoices",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "invoices"
          ]
        }
      }
    },
    {
      "name": "List Invoices",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{tenantToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/invoices",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "invoices"
          ]
        }
      }
    },
    {
      "name": "Get Invoice",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{tenantToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/invoices/{{invoiceId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "invoices",
            "{{invoiceId}}"
          ]
        }
      }
    }
  ]
}