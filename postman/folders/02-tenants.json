{
  "name": "Tenants",
  "item": [
    {
      "name": "Create Tenant",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const r = pm.response.json();",
              "if (r.auth?.accessToken)  pm.collectionVariables.set('tenantToken',  r.auth.accessToken);",
              "if (r.auth?.refreshToken) pm.collectionVariables.set('refreshToken', r.auth.refreshToken);",
              "if (r.tenantId)           pm.collectionVariables.set('tenantId', r.tenantId);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{publicToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"companyName\": \"Acme Corporation\",\n  \"dataSourceType\": \"external\",\n  \"subscriptionPlan\": \"enterprise\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/tenants",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "tenants"
          ]
        }
      }
    },
    {
      "name": "Get Tenant",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{tenantToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/tenants/{{tenantId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "tenants",
            "{{tenantId}}"
          ]
        }
      }
    },
    {
      "name": "List All Tenants",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{tenantToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/tenants",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "tenants"
          ]
        }
      }
    },
    {
      "name": "Delete Tenant",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{tenantToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/tenants/{{tenantId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "tenants",
            "{{tenantId}}"
          ]
        }
      }
    }
  ]
}