{
  "name": "Chat — REST",
  "item": [
    {
      "name": "Create Chat Session",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const r = pm.response.json();",
              "if (r.id) pm.collectionVariables.set('sessionId', r.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{tenantToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": ""
        },
        "url": {
          "raw": "{{baseUrl}}/chat/sessions",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "chat",
            "sessions"
          ]
        }
      }
    },
    {
      "name": "Get Chat Session",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{tenantToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/chat/sessions/{{sessionId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "chat",
            "sessions",
            "{{sessionId}}"
          ]
        }
      }
    }
  ]
}