{
  "name": "erp-middleware",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli",
    "migration:run": "npm run typeorm -- migration:run -d ormconfig.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d ormconfig.ts",
    "migration:show": "npm run typeorm -- migration:show -d ormconfig.ts",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "test:e2e:watch": "jest --config ./test/jest-e2e.json --watch --runInBand",
    "test:e2e:cov": "jest --config ./test/jest-e2e.json --coverage --runInBand",
    "test:e2e:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --config ./test/jest-e2e.json --runInBand",
    "test:e2e:public": "jest --config ./test/jest-e2e.json --testPathPatterns=public --runInBand",
    "test:e2e:tenant": "jest --config ./test/jest-e2e.json --testPathPatterns=tenant --runInBand",
    "test:e2e:integration": "jest --config ./test/jest-e2e.json --testPathPatterns=integration --runInBand",
    "test:e2e:single": "jest --config ./test/jest-e2e.json --runInBand"
  },
  "dependencies": {
    "@apollo/server": "^5.4.0",
    "@as-integrations/express5": "^1.1.2",
    "@aws-sdk/client-kms": "^3.990.0",
    "@aws-sdk/client-secrets-manager": "^3.990.0",
    "@google/genai": "^1.41.0",
    "@google/generative-ai": "^0.24.1",
    "@nestjs-modules/ioredis": "^2.0.2",
    "@nestjs/apollo": "^13.2.4",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^11.1.11",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.11",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/graphql": "^13.2.4",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.11",
    "@nestjs/schedule": "^6.1.0",
    "@nestjs/swagger": "^11.2.4",
    "@nestjs/typeorm": "^11.0.0",
    "@types/graphql": "^14.2.3",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.17",
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.2.3",
    "graphql": "^16.12.0",
    "graphql-subscriptions": "^3.0.0",
    "graphql-type-json": "^0.3.2",
    "ioredis": "^5.9.3",
    "multer": "^2.1.0",
    "openai": "^6.22.0",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.16.3",
    "prom-client": "^15.1.3",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.14",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/bull": "^3.15.9",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/long": "^4.0.2",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.19.6",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.2.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(uuid)/)"
    ],
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@config/(.*)$": "<rootDir>/config/$1",
      "^@database/(.*)$": "<rootDir>/database/$1",
      "^@auth/(.*)$": "<rootDir>/auth/$1",
      "^@tenants/(.*)$": "<rootDir>/tenants/$1",
      "^@users/(.*)$": "<rootDir>/users/$1",
      "^@subscription/(.*)$": "<rootDir>/subscription/$1",
      "^subscription-plans/(.*)$": "<rootDir>/subscription-plans/$1",
      "^@connectors/(.*)$": "<rootDir>/connectors/$1",
      "^@finance/(.*)$": "<rootDir>/finance/$1",
      "^@dashboards/(.*)$": "<rootDir>/dashboards/$1",
      "^@ai/(.*)$": "<rootDir>/ai/$1",
      "^@chat/(.*)$": "<rootDir>/chat/$1",
      "^@audit/(.*)$": "<rootDir>/audit/$1",
      "^@common/(.*)$": "<rootDir>/common/$1",
      "^@etl/(.*)$": "<rootDir>/etl/$1"
    }
  }
}
