{
  "info": {
    "name": "ERP Middleware API",
    "description": "Complete API collection for AI-Powered ERP Middleware",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api",
      "type": "string"
    },
    {
      "key": "publicToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "tenantToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"SecurePass123!\",\n  \"fullName\": \"Admin User\",\n  \"role\": \"ADMIN\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "pm.collectionVariables.set('publicToken', response.access_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh"]
            }
          }
        }
      ]
    },
    {
      "name": "Tenants",
      "item": [
        {
          "name": "Create Tenant",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "pm.collectionVariables.set('tenantToken', response.auth.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{publicToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyName\": \"Acme Corporation\",\n  \"dataSourceType\": \"external\",\n  \"subscriptionPlan\": \"enterprise\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tenants",
              "host": ["{{baseUrl}}"],
              "path": ["tenants"]
            }
          }
        },
        {
          "name": "Get Tenant",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tenantToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/tenants/:id",
              "host": ["{{baseUrl}}"],
              "path": ["tenants", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "{{tenantId}}"
                }
              ]
            }
          }
        },
        {
          "name": "List All Tenants",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tenantToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/tenants",
              "host": ["{{baseUrl}}"],
              "path": ["tenants"]
            }
          }
        }
      ]
    },
    {
      "name": "Invoices",
      "item": [
        {
          "name": "Create Invoice",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{tenantToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_name\": \"Client Corp\",\n  \"amount\": 5000.00,\n  \"currency\": \"USD\",\n  \"status\": \"pending\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/invoices",
              "host": ["{{baseUrl}}"],
              "path": ["invoices"]
            }
          }
        },
        {
          "name": "List Invoices",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tenantToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/invoices",
              "host": ["{{baseUrl}}"],
              "path": ["invoices"]
            }
          }
        },
        {
          "name": "Get Invoice",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tenantToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/invoices/:id",
              "host": ["{{baseUrl}}"],
              "path": ["invoices", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "{{invoiceId}}"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "CSV Upload",
      "item": [
        {
          "name": "Upload CSV",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tenantToken}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "/path/to/invoices.csv"
                },
                {
                  "key": "entityType",
                  "value": "invoice",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/connectors/csv-upload",
              "host": ["{{baseUrl}}"],
              "path": ["connectors", "csv-upload"]
            }
          }
        }
      ]
    },
    {
      "name": "Quarantine",
      "item": [
        {
          "name": "List Quarantine Records",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tenantToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/quarantine",
              "host": ["{{baseUrl}}"],
              "path": ["quarantine"]
            }
          }
        },
        {
          "name": "Get Quarantine Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tenantToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/quarantine/status",
              "host": ["{{baseUrl}}"],
              "path": ["quarantine", "status"]
            }
          }
        },
        {
          "name": "Retry Quarantine Record",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{tenantToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fixedData\": {\n    \"customer_name\": \"Fixed Customer Corp\",\n    \"amount\": 2000.00,\n    \"external_id\": \"INV-101\",\n    \"status\": \"paid\",\n    \"currency\": \"USD\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/quarantine/:id/retry",
              "host": ["{{baseUrl}}"],
              "path": ["quarantine", ":id", "retry"],
              "variable": [
                {
                  "key": "id",
                  "value": "{{quarantineId}}"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Finance Dashboard",
      "item": [
        {
          "name": "Get Dashboard",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tenantToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/finance/dashboard",
              "host": ["{{baseUrl}}"],
              "path": ["finance", "dashboard"]
            }
          }
        }
      ]
    },
    {
      "name": "Subscription Plans",
      "item": [
        {
          "name": "List Plans",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/subscription-plans",
              "host": ["{{baseUrl}}"],
              "path": ["subscription-plans"]
            }
          }
        }
      ]
    }
  ]
}
