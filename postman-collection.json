    {
      "name": "GraphQL — Analytics",
      "item": [
        {
          "name": "Revenue by Month",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tenantToken}}" },
              { "key": "x-tenant-id", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query RevenueByMonth($year: Int!) {\\n  revenueByMonth(year: $year) {\\n    month\\n    year\\n    revenue\\n    currency\\n  }\\n}\",\n  \"variables\": { \"year\": 2024 }\n}"
            },
            "url": { "raw": "{{graphqlUrl}}", "host": ["{{graphqlUrl}}"] }
          }
        },
        {
          "name": "Expense Breakdown",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tenantToken}}" },
              { "key": "x-tenant-id", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query ExpenseBreakdown($from: String!, $to: String!) {\\n  expenseBreakdown(from: $from, to: $to) {\\n    category\\n    vendorId\\n    vendorName\\n    total\\n    currency\\n  }\\n}\",\n  \"variables\": {\n    \"from\": \"2024-01-01T00:00:00Z\",\n    \"to\": \"2024-03-31T23:59:59Z\"\n  }\n}"
            },
            "url": { "raw": "{{graphqlUrl}}", "host": ["{{graphqlUrl}}"] }
          }
        },
        {
          "name": "Cash Position",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tenantToken}}" },
              { "key": "x-tenant-id", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query CashPosition($asOf: String) {\\n  cashPosition(asOf: $asOf) {\\n    balance\\n    currency\\n    asOf\\n  }\\n}\",\n  \"variables\": { \"asOf\": \"2024-03-31\" }\n}"
            },
            "url": { "raw": "{{graphqlUrl}}", "host": ["{{graphqlUrl}}"] }
          }
        }
      ]
    },
    {
      "name": "GraphQL — Anomalies",
      "item": [
        {
          "name": "List Anomalies",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "const list = r.data?.anomalies ?? [];",
                  "if (list.length) pm.collectionVariables.set('insightId', list[0].id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tenantToken}}" },
              { "key": "x-tenant-id", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query Anomalies($types: [String], $minScore: Float) {\\n  anomalies(types: $types, minScore: $minScore) {\\n    id\\n    type\\n    score\\n    confidence\\n    explanation\\n    relatedIds\\n    detectedAt\\n  }\\n}\",\n  \"variables\": {\n    \"types\": [\"EXPENSE_SPIKE\", \"DUPLICATE_INVOICE\"],\n    \"minScore\": 0.5\n  }\n}"
            },
            "url": { "raw": "{{graphqlUrl}}", "host": ["{{graphqlUrl}}"] }
          }
        },
        {
          "name": "Get Anomaly",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tenantToken}}" },
              { "key": "x-tenant-id", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query Anomaly($id: ID!) {\\n  anomaly(id: $id) {\\n    id\\n    type\\n    score\\n    confidence\\n    explanation\\n    relatedIds\\n    detectedAt\\n  }\\n}\",\n  \"variables\": { \"id\": \"{{insightId}}\" }\n}"
            },
            "url": { "raw": "{{graphqlUrl}}", "host": ["{{graphqlUrl}}"] }
          }
        }
      ]
    },
    {
      "name": "GraphQL — Chat",
      "item": [
        {
          "name": "Create Chat Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "const s = r.data?.createChatSession;",
                  "if (s?.id) pm.collectionVariables.set('sessionId', s.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tenantToken}}" },
              { "key": "x-tenant-id", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation {\\n  createChatSession {\\n    id\\n    createdAt\\n    messages {\\n      id\\n      role\\n      content\\n      createdAt\\n    }\\n  }\\n}\"\n}"
            },
            "url": { "raw": "{{graphqlUrl}}", "host": ["{{graphqlUrl}}"] }
          }
        },
        {
          "name": "Get Chat Session",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tenantToken}}" },
              { "key": "x-tenant-id", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query ChatSession($id: ID!) {\\n  chatSession(id: $id) {\\n    id\\n    createdAt\\n    messages {\\n      id\\n      sessionId\\n      role\\n      content\\n      latencyMs\\n      createdAt\\n    }\\n  }\\n}\",\n  \"variables\": { \"id\": \"{{sessionId}}\" }\n}"
            },
            "url": { "raw": "{{graphqlUrl}}", "host": ["{{graphqlUrl}}"] }
          }
        },
        {
          "name": "Send Message",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "const m = r.data?.sendMessage;",
                  "if (m?.id) pm.collectionVariables.set('messageId', m.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
