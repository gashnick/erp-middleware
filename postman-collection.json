    {
      "name": "Insights (Anomalies) — REST",
      "item": [
        {
          "name": "1. Trigger Anomaly Scan",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Scan is async — job is enqueued and processed in background.",
                  "// The next request (List Insights) should be run manually after",
                  "// a few seconds, or use the Postman Collection Runner with a",
                  "// delay set between requests.",
                  "pm.test('Scan enqueued', () => {",
                  "  pm.response.to.have.status(201);",
                  "  const r = pm.response.json();",
                  "  pm.expect(r.jobId).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tenantToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "" },
            "url": {
              "raw": "{{baseUrl}}/insights/scan",
              "host": ["{{baseUrl}}"],
              "path": ["insights", "scan"]
            }
          }
        },
        {
          "name": "2. List Insights",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns array', () => pm.response.to.have.status(200));",
                  "",
                  "const r = pm.response.json();",
                  "const list = Array.isArray(r) ? r : (r.data ?? []);",
                  "",
                  "pm.test('At least one anomaly detected', () => {",
                  "  pm.expect(list.length).to.be.greaterThan(0);",
                  "});",
                  "",
                  "// Save first anomaly ID for subsequent requests",
                  "if (list.length) {",
                  "  pm.collectionVariables.set('insightId', list[0].id);",
                  "  console.log('insightId set to:', list[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tenantToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/insights?types=EXPENSE_SPIKE,DUPLICATE_INVOICE&minScore=0.5",
              "host": ["{{baseUrl}}"],
              "path": ["insights"],
              "query": [
                { "key": "types", "value": "EXPENSE_SPIKE,DUPLICATE_INVOICE" },
                { "key": "minScore", "value": "0.5" }
              ]
            }
          }
        },
        {
          "name": "3. Get Insight",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns single anomaly', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const r = pm.response.json();",
                  "  pm.expect(r.id).to.eql(pm.collectionVariables.get('insightId'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tenantToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/insights/{{insightId}}",
              "host": ["{{baseUrl}}"],
              "path": ["insights", "{{insightId}}"]
            }
          }
        },
        {
          "name": "4. Submit Insight Feedback",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Guard — abort if insightId was never set by List Insights",
                  "const id = pm.collectionVariables.get('insightId');",
                  "if (!id) throw new Error('insightId not set — run List Insights first');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Feedback created', () => {",
                  "  pm.response.to.have.status(201);",
                  "  const r = pm.response.json();",
                  "  pm.expect(r.id).to.exist;",
                  "  pm.expect(r.rating).to.eql('helpful');",
                  "  pm.expect(r.insightId).to.eql(pm.collectionVariables.get('insightId'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tenantToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": \"helpful\",\n  \"comment\": \"This correctly flagged a seasonal spike.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/insights/{{insightId}}/feedback",
              "host": ["{{baseUrl}}"],
              "path": ["insights", "{{insightId}}", "feedback"]
            }
          }
        }
      ]
    },
