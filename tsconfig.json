{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": false,
    "forceConsistentCasingInFileNames": false,
    "noFallthroughCasesInSwitch": false,
    "allowJs": true,
    "esModuleInterop": true,
    "types": ["node", "jest", "Multer"],
    "paths": {
      "@config/*": ["src/config/*"],
      "@database/*": ["src/database/*"],
      "@auth/*": ["src/auth/*"],
      "@tenants/*": ["src/tenants/*"],
      "@users/*": ["src/users/*"],
      "@subscription/*": ["src/subscription/*"],
      "@connectors/*": ["src/connectors/*"],
      "@finance/*": ["src/finance/*"],
      "@dashboards/*": ["src/dashboards/*"],
      "@ai/*": ["src/ai/*"],
      "@chat/*": ["src/chat/*"],
      "@audit/*": ["src/audit/*"],
      "@common/*": ["src/common/*"],
      "@analytics/*": ["src/analytics/*"],
      "@anomaly/*": ["src/anomaly/*"],
      "chat/*": ["src/chat/*"],
      "@backup/*": ["src/backup/*"],
      "@graphql/*": ["src/graphql/*"],
      "@jobs/*": ["src/jobs/*"],
      "@knowledgeGraph/*": ["src/knowledgeGraph/*"],
      "@admin/*": ["src/admin/*"],
      "@subscription-plans/*": ["src/subscription-plans/*"],
      "@alerts/*": ["src/alerts/*"],
      "@notifications/*": ["src/notifications/*"],
      "@hr/*": ["src/hr/*"]
    }
  }
}
